{
  "appId": "ai.saferl.cheetahclaws",
  "appName": "CheetahClaws",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": ["*"]
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0b0b0e"
  },
  "android": {
    "backgroundColor": "#0b0b0e"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 600,
      "backgroundColor": "#0b0b0e",
      "showSpinner": false
    }
  }
}
